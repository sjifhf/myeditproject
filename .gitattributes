# ========== Unity 專案換行與二進位檔設定 ==========

# 所有文字檔統一使用 LF
* text=auto eol=lf

# 二進位檔忽略換行轉換
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.psd binary
*.fbx binary
*.mat binary
*.prefab binary
*.anim binary
*.controller binary
*.renderTexture binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.mov binary
*.dll binary
*.exe binary
*.so binary
*.a binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary

# 特定 Unity 設定檔（避免換行亂掉）
ProjectSettings/* text eol=lf
UserSettings/* text eol=lf
